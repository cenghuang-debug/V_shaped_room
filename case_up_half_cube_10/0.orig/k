FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 3.75e-05;

boundaryField
{
    left
    {
        type            symmetryPlane;
    }
    right
    {
        type            inletOutlet;
        inletValue      uniform 3.75e-05;
        value           uniform 3.75e-05;
    }
    top
    {
        type            inletOutlet;
        inletValue      uniform 3.75e-05;
        value           uniform 3.75e-05;
    }
    bottom
    {
        type            inletOutlet;
        inletValue      uniform 3.75e-05;
        value           uniform 3.75e-05;
    }
    front
    {
        type            inletOutlet;
        inletValue      uniform 3.75e-05;
        value           uniform 3.75e-05;
    }
    back
    {
        type            inletOutlet;
        inletValue      uniform 3.75e-05;
        value           uniform 3.75e-05;
    }
    walls
    {
        type            kqRWallFunction;
        value           uniform 3.75e-05;
    }
    source
    {
        type            fixedValue;
        value           uniform 1.5e2; //5400;
    }
    nozzle_wall_rest
    {
        type            kqRWallFunction;
        value           uniform 3.75e-05;
    }
}


