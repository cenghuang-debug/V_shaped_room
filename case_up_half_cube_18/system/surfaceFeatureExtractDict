FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      surfaceFeatureExtractDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

V_room_m.stl
{
    extractionMethod    extractFromSurface;

    includedAngle       170;

    subsetFeatures
    {
        nonManifoldEdges no;
        openEdges        yes;
    }

    writeObj            yes;
}

nozzle_m.stl
{
    extractionMethod    extractFromSurface;

    includedAngle       170;

    subsetFeatures
    {
        nonManifoldEdges no;
        openEdges        yes;
    }

    writeObj            yes;
}

