FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}

dimensions      [0 2 -2 0 0 0 0];

// k = 1.5*(I*U)^2 = 1.5*(0.01*0.5)^2 ~ 3.75e-5 for ambient (U~0.5 m/s, I=5%)
internalField   uniform 3.75e-5;

boundaryField
{
    left
    {
        type            symmetryPlane;
    }

    right
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    top
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    bottom
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    front
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    back
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    walls
    {
        type            kqRWallFunction;
        value           $internalField;
    }

    // Birch 1987: k = 1.5*(I*V_n)^2, I=5%, V_n=2008.25 m/s -> k=15124
    source
    {
        type            fixedValue;
        value           uniform 15124.06;
    }

    nozzle_wall_rest
    {
        type            kqRWallFunction;
        value           $internalField;
    }
}
