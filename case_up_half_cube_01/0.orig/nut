FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 4.6e-5; 

boundaryField
{

    walls
    {
        type            nutkWallFunction;
        value           $internalField;
    }
    vent_a
    {
        type            calculated;
        value           $internalField;
    }
    vent_b
    {
        type            calculated;
        value           $internalField;
    }
}
